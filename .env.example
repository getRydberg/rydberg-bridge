# Path to your Rydberg core repo, so Bridge can read modules.list and show
# installed-module status. Not required — if this path doesn't exist,
# Bridge just shows an empty modules list; everything else still works.
# Leave unset if running standalone with no core repo at all.
RYDBERG_ROOT=~/Rydberg

# Read by the BROWSER, so this can never be a container name.
# Production behind Cloudflare Tunnel path-routing: leave as the default
# relative "/api" (same origin as the frontend).
# Local dev without Cloudflare: only if you've added a host port mapping
# to backend-bridge, point this at http://localhost:<that-port>.
VITE_API_BASE_URL=/api
